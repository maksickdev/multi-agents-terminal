{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "dialog:allow-message",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-rename",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-read-dir",
    "fs:allow-stat",
    "fs:allow-remove",
    "opener:default",
    "opener:allow-open-url"
  ]
}
