{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Multi-Agent Terminal",
  "version": "0.1.0",
  "identifier": "com.multiagent.terminal",
  "build": {
    "beforeDevCommand": "npx concurrently \"npm run dev\" \"npm run server\"",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Multi-Agent Terminal",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
